{
  "name": "aso-scout",
  "version": "0.2.0",
  "description": "CLI for early ASO name research across App Store, Google Play, and domains.",
  "type": "module",
  "bin": {
    "aso-scout": "./bin/aso-scout.js"
  },
  "scripts": {
    "check": "node --check bin/aso-scout.js",
    "sample": "node bin/aso-scout.js --names examples/names.txt --country us",
    "sample:offline": "node bin/aso-scout.js --names examples/names.txt --no-app-store --no-google-play --no-domains"
  },
  "keywords": [
    "aso",
    "app-store",
    "google-play",
    "app-name",
    "keywords",
    "cli"
  ],
  "author": "Sakov",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mladishiis/aso-scout.git"
  },
  "bugs": {
    "url": "https://github.com/mladishiis/aso-scout/issues"
  },
  "homepage": "https://github.com/mladishiis/aso-scout#readme"
}
